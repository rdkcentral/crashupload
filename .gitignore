# =============================================================================
# Global build artifacts (apply throughout the entire tree)
# =============================================================================

# Compiled object files
*.o

# GCC/LLVM coverage instrumentation
*.gcda
*.gcno

# Automake dependency-tracking dirs and stamp files
.deps/
.dirstamp

# Autoconf cache (generated by autoreconf / autoconf)
autom4te.cache/

# =============================================================================
# c_sourcecode/ — autoconf/automake generated files
# =============================================================================

# Generated by ./configure (from Makefile.am / Makefile.in)
# NOTE: c_sourcecode/src/Makefile.am is a source file and is NOT ignored.
#       src/Makefile (root src/) is a hand-written file and is NOT ignored.
c_sourcecode/Makefile
c_sourcecode/src/Makefile

# Autoconf output files
c_sourcecode/config.status
c_sourcecode/config.log
c_sourcecode/config.h
c_sourcecode/config.h.in
c_sourcecode/stamp-h1

# Compiled crashupload binary
c_sourcecode/src/crashupload

# =============================================================================
# unittest/ — autoconf/automake build system and compiled test binaries
# =============================================================================

# Autoconf / automake generated scripts and metadata
unittest/aclocal.m4
unittest/ar-lib
unittest/compile
unittest/config.guess
unittest/config.h
unittest/config.h.in
unittest/config.status
unittest/config.sub
unittest/configure
unittest/depcomp
unittest/install-sh
unittest/missing
unittest/stamp-h1
unittest/test-driver

# Generated Makefiles (source is unittest/Makefile.am — NOT ignored)
unittest/Makefile
unittest/Makefile.in

# Coverage report files
unittest/coverage.info
unittest/coverage.filtered.info
unittest/coverage_html/

# Compiled test binaries
unittest/archive_gtest
unittest/config_manager_gtest
unittest/lock_manager_gtest
unittest/logger_gtest
unittest/mainapp_gtest
unittest/platform_gtest
unittest/prerequisites_gtest
unittest/ratelimit_gtest
unittest/scanner_gtest
unittest/upload_gtest
unittest/utils_gtest
